# Environment example for CACTUS-Panel-Ai

# OAuth
OAUTH_GITHUB_ID=
OAUTH_GITHUB_SECRET=
OAUTH_GOOGLE_ID=
OAUTH_GOOGLE_SECRET=

# SMTP (for email login)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Render (optional, for CI deployment)
RENDER_API_KEY=
RENDER_SERVICE_ID=

# App
PORT=3000
NODE_ENV=development
